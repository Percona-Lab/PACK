#!/usr/bin/env node

import { join } from 'path';
import { homedir } from 'os';
import dotenv from 'dotenv';
import { GitHubConnector } from '../connectors/github.js';
import { MemorySyncManager } from '../connectors/memory-sync.js';
import { MemoryCore } from '../core/memory.js';

// Load env
dotenv.config({ path: join(homedir(), '.pack.env'), override: true });

const args = process.argv.slice(2);
const command = args[0];

function getFlag(name) {
  const idx = args.indexOf(`--${name}`);
  if (idx === -1) return null;
  return args[idx + 1] || true;
}

function hasFlag(name) {
  return args.includes(`--${name}`);
}

function usage() {
  console.log(`
PACK — Portable Agent Context Keeper

Usage:
  pack init                          # bootstrap directory structure
  pack list [--tag TAG] [--dir DIR] [--format json]
  pack get <path> [--no-frontmatter] [--json]
  pack update <path> [--file FILE] [--message MSG]
  pack search <query> [--format json]
  pack migrate [--dry-run] [--yes]
  pack migrate-notion [--dry-run]
  pack sync [--target TARGET] [--dry-run]
  pack validate
  pack status
  pack help
`);
}

async function main() {
  if (!command || command === 'help' || command === '--help') {
    usage();
    process.exit(0);
  }

  const github = new GitHubConnector(
    process.env.GITHUB_TOKEN,
    process.env.GITHUB_OWNER,
    process.env.GITHUB_REPO,
    process.env.GITHUB_MEMORY_PATH || 'MEMORY.md'
  );
  const core = new MemoryCore(github);

  switch (command) {
    case 'list': {
      const result = await core.list({
        tag: getFlag('tag'),
        topic: getFlag('topic'),
        dir: getFlag('dir'),
      });
      if (hasFlag('format') && getFlag('format') === 'json') {
        console.log(JSON.stringify(result, null, 2));
      } else {
        console.log(result.content);
      }
      break;
    }

    case 'get': {
      const path = args[1];
      if (!path) {
        console.error('Error: path required. Usage: pack get <path>');
        process.exit(1);
      }
      const result = await core.get(path);
      if (result.error) {
        console.error(result.error);
        process.exit(1);
      }
      if (hasFlag('json')) {
        console.log(JSON.stringify(result, null, 2));
      } else if (hasFlag('no-frontmatter')) {
        const { parse } = await import('../core/frontmatter.js');
        const { body } = parse(result.content);
        console.log(body);
      } else {
        console.log(result.content);
      }
      break;
    }

    case 'update': {
      const path = args[1];
      if (!path) {
        console.error('Error: path required. Usage: pack update <path> [--file FILE] [--message MSG]');
        process.exit(1);
      }

      let content;
      const filePath = getFlag('file');
      if (filePath) {
        const { readFileSync } = await import('fs');
        content = readFileSync(filePath, 'utf-8');
      } else {
        // Read from stdin
        const chunks = [];
        for await (const chunk of process.stdin) {
          chunks.push(chunk);
        }
        content = Buffer.concat(chunks).toString('utf-8');
      }

      if (!content.trim()) {
        console.error('Error: no content provided. Pipe content or use --file');
        process.exit(1);
      }

      const message = getFlag('message');
      try {
        const result = await core.update({ path, content, message });
        console.log(`Updated ${result.path} (sha: ${result.sha})`);
        if (result.warning) console.error(result.warning);
      } catch (err) {
        if (err.message.includes('409')) {
          console.error('Conflict: file was modified since last read. Fetch and retry.');
          process.exit(2);
        }
        throw err;
      }
      break;
    }

    case 'search': {
      const query = args[1];
      if (!query) {
        console.error('Error: query required. Usage: pack search <query>');
        process.exit(1);
      }
      const result = await core.search(query);
      if (hasFlag('format') && getFlag('format') === 'json') {
        console.log(JSON.stringify(result, null, 2));
      } else {
        if (result.results.length === 0) {
          console.log('No matches found.');
        } else {
          for (const r of result.results) {
            console.log(`\n${r.path} (${r.topic}) [${Array.isArray(r.tags) ? r.tags.join(', ') : ''}]`);
            console.log(r.snippet);
          }
        }
      }
      break;
    }

    case 'migrate': {
      const dryRun = hasFlag('dry-run');
      const result = await core.migrate({ dryRun });

      if (result.error) {
        console.error(result.error);
        process.exit(1);
      }

      console.log(`\nMigration ${dryRun ? 'plan' : 'complete'}: ${result.fileCount} files\n`);
      for (const f of result.plan) {
        console.log(`  ${f.path} (${f.topic})`);
        console.log(`    ${f.preview}\n`);
      }

      if (!dryRun) {
        console.log(result.message);
        console.log('\nPost-migration checklist:');
        console.log('  [ ] Check taxonomy: are files in the right directories?');
        console.log('  [ ] Check tags: do they make sense for your filtering needs?');
        console.log('  [ ] Update sync_order in index.md if needed');
        console.log('  [ ] Update system prompts in all AI clients (see README)');
        console.log('  [ ] Run: pack status && pack validate');
      }
      break;
    }

    case 'migrate-notion': {
      const dryRun = hasFlag('dry-run');

      if (!process.env.NOTION_TOKEN || !process.env.NOTION_SYNC_PAGE_ID) {
        console.error('Error: NOTION_TOKEN and NOTION_SYNC_PAGE_ID must be set in ~/.pack.env');
        process.exit(1);
      }

      const modeCheck = await core.detectMode();
      if (modeCheck === 'v1') {
        console.error('Error: Run `pack migrate` first to switch to directory mode.');
        process.exit(1);
      }

      const syncManager = new MemorySyncManager();
      await syncManager.init();
      syncManager.setGitHubConnector(github);

      // Gather all files with metadata
      const files = await core.getFilesWithMeta();
      const fullContent = await core.getSyncContent();

      console.log(`\nNotion migration ${dryRun ? 'plan' : 'starting'}: ${files.length} files\n`);

      const result = await syncManager.migrateNotion(files, fullContent, { dryRun });

      if (dryRun) {
        if (result.created.length) {
          console.log(`  Would create ${result.created.length} pages:`);
          for (const p of result.created) console.log(`    + ${p}`);
        }
        if (result.skipped.length) {
          console.log(`  Would skip ${result.skipped.length} existing pages:`);
          for (const p of result.skipped) console.log(`    = ${p}`);
        }
        if (!result.fullExportPageId) {
          console.log('  Would create: PACK Full Export (read-only)');
        }
        console.log('\nRun without --dry-run to execute.');
      } else {
        console.log(`  Created: ${result.created.length} pages`);
        if (result.created.length) {
          for (const p of result.created) console.log(`    + ${p}`);
        }
        console.log(`  Skipped: ${result.skipped.length} existing pages`);
        console.log(`  Full export page: ${result.fullExportPageId ? 'ok' : 'created'}`);
        console.log(`  Index page: updated`);
        console.log('\nNotion migration complete.');
        console.log('\nNext steps:');
        console.log('  1. Set NOTION_SYNC_MODE=multi in ~/.pack.env');
        console.log('  2. Restart your MCP server (quit and reopen your AI client)');
        console.log('  3. Verify pages in Notion');
      }
      break;
    }

    case 'sync': {
      const syncManager = new MemorySyncManager();
      await syncManager.init();
      syncManager.setGitHubConnector(github);

      if (!syncManager.enabled) {
        console.log('No sync targets configured.');
        process.exit(0);
      }

      const target = getFlag('target');
      const content = await core.getSyncContent();

      if (hasFlag('dry-run')) {
        console.log(`Would sync ${content.length} chars to: ${syncManager.targets.join(', ')}`);
        if (syncManager.notionSyncMode === 'multi') {
          console.log('  Notion mode: multi-page');
        }
        console.log('\n--- Preview (first 500 chars) ---');
        console.log(content.slice(0, 500));
        break;
      }

      console.log(`Syncing to: ${target || syncManager.targets.join(', ')}`);
      await syncManager.sync(content);
      console.log('Sync complete.');
      break;
    }

    case 'validate': {
      const result = await core.validate();
      if (result.mode === 'v1') {
        console.log(result.message);
        break;
      }

      console.log(`Checked ${result.fileCount} files`);

      if (result.errors.length) {
        console.log(`\nErrors (${result.errors.length}):`);
        for (const e of result.errors) console.log(`  ERROR: ${e}`);
      }

      if (result.warnings.length) {
        console.log(`\nWarnings (${result.warnings.length}):`);
        for (const w of result.warnings) console.log(`  WARN: ${w}`);
      }

      if (result.valid) {
        console.log('\nAll checks passed.');
      }

      process.exit(result.valid ? 0 : 1);
      break;
    }

    case 'status': {
      const result = await core.status();
      if (result.mode === 'v1') {
        console.log(`PACK v1 | 1 file | ${result.repo}`);
      } else {
        console.log(`PACK v2 | ${result.fileCount} files | Last updated: ${result.lastUpdated}`);
        console.log(`Mode:       v2 (directory)`);
        console.log(`Repo:       ${result.repo}`);
        if (result.directories) {
          const dirs = Object.entries(result.directories).map(([d, c]) => `${c} ${d}`).join(', ');
          console.log(`Files:      ${dirs}`);
        }
      }
      break;
    }

    case 'init': {
      const mode = await core.detectMode();
      if (mode === 'v2') {
        console.log('Already initialized. Nothing to do.');
        break;
      }

      // Check if there's existing v1 content to migrate instead
      const memory = await github.getMemory();
      if (memory.content && memory.content.trim().length > 0) {
        console.log('Existing memory detected (single-file format).');
        console.log('');
        console.log('Run `pack migrate` to upgrade to directory mode.');
        console.log('This reduces token usage by ~94% and keeps cost flat as memory grows.');
        console.log('');
        console.log('  pack migrate --dry-run    # preview changes');
        console.log('  pack migrate              # run migration');
        process.exit(1);
      }

      // Bootstrap empty v2 structure
      const today = new Date().toISOString().slice(0, 10);
      const { serialize } = await import('../core/frontmatter.js');
      const { buildIndex } = await import('../core/index-builder.js');

      const welcomeContent = serialize({
        topic: 'general',
        tags: ['general'],
        created: today,
        updated: today,
        sync: true,
      }, 'Welcome to PACK. Use memory_update to save information here.\n');

      await github.putContents('context/general.md', welcomeContent, null, 'Initialize PACK');

      const indexContent = buildIndex([{ path: 'context/general.md', content: welcomeContent }]);
      await github.putContents('index.md', indexContent, null, 'Initialize PACK index');

      console.log('PACK initialized.');
      console.log('  Created: context/general.md');
      console.log('  Created: index.md');
      console.log('\nAdd the system prompt to your AI clients (see README).');
      console.log('Run `pack status` to verify.');
      break;
    }

    default:
      console.error(`Unknown command: ${command}`);
      usage();
      process.exit(1);
  }
}

main().catch(err => {
  console.error(`Error: ${err.message}`);
  process.exit(1);
});
