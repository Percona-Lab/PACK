#!/usr/bin/env node

import { join } from 'path';
import { homedir } from 'os';
import dotenv from 'dotenv';
import { GitHubConnector } from '../connectors/github.js';
import { MemorySyncManager } from '../connectors/memory-sync.js';
import { MemoryCore } from '../core/memory.js';

// Load env
dotenv.config({ path: join(homedir(), '.pack.env'), override: true });

const args = process.argv.slice(2);
const command = args[0];

function getFlag(name) {
  const idx = args.indexOf(`--${name}`);
  if (idx === -1) return null;
  return args[idx + 1] || true;
}

function hasFlag(name) {
  return args.includes(`--${name}`);
}

function usage() {
  console.log(`
PACK — Portable Agent Context Keeper

Usage:
  pack list [--tag TAG] [--dir DIR] [--format json]
  pack get <path> [--no-frontmatter] [--json]
  pack update <path> [--file FILE] [--message MSG]
  pack search <query> [--format json]
  pack migrate [--dry-run] [--yes]
  pack sync [--target TARGET] [--dry-run]
  pack validate
  pack status
  pack help
`);
}

async function main() {
  if (!command || command === 'help' || command === '--help') {
    usage();
    process.exit(0);
  }

  const github = new GitHubConnector(
    process.env.GITHUB_TOKEN,
    process.env.GITHUB_OWNER,
    process.env.GITHUB_REPO,
    process.env.GITHUB_MEMORY_PATH || 'MEMORY.md'
  );
  const core = new MemoryCore(github);

  switch (command) {
    case 'list': {
      const result = await core.list({
        tag: getFlag('tag'),
        topic: getFlag('topic'),
        dir: getFlag('dir'),
      });
      if (hasFlag('format') && getFlag('format') === 'json') {
        console.log(JSON.stringify(result, null, 2));
      } else {
        console.log(result.content);
      }
      break;
    }

    case 'get': {
      const path = args[1];
      if (!path) {
        console.error('Error: path required. Usage: pack get <path>');
        process.exit(1);
      }
      const result = await core.get(path);
      if (result.error) {
        console.error(result.error);
        process.exit(1);
      }
      if (hasFlag('json')) {
        console.log(JSON.stringify(result, null, 2));
      } else if (hasFlag('no-frontmatter')) {
        const { parse } = await import('../core/frontmatter.js');
        const { body } = parse(result.content);
        console.log(body);
      } else {
        console.log(result.content);
      }
      break;
    }

    case 'update': {
      const path = args[1];
      if (!path) {
        console.error('Error: path required. Usage: pack update <path> [--file FILE] [--message MSG]');
        process.exit(1);
      }

      let content;
      const filePath = getFlag('file');
      if (filePath) {
        const { readFileSync } = await import('fs');
        content = readFileSync(filePath, 'utf-8');
      } else {
        // Read from stdin
        const chunks = [];
        for await (const chunk of process.stdin) {
          chunks.push(chunk);
        }
        content = Buffer.concat(chunks).toString('utf-8');
      }

      if (!content.trim()) {
        console.error('Error: no content provided. Pipe content or use --file');
        process.exit(1);
      }

      const message = getFlag('message');
      try {
        const result = await core.update({ path, content, message });
        console.log(`Updated ${result.path} (sha: ${result.sha})`);
        if (result.warning) console.error(result.warning);
      } catch (err) {
        if (err.message.includes('409')) {
          console.error('Conflict: file was modified since last read. Fetch and retry.');
          process.exit(2);
        }
        throw err;
      }
      break;
    }

    case 'search': {
      const query = args[1];
      if (!query) {
        console.error('Error: query required. Usage: pack search <query>');
        process.exit(1);
      }
      const result = await core.search(query);
      if (hasFlag('format') && getFlag('format') === 'json') {
        console.log(JSON.stringify(result, null, 2));
      } else {
        if (result.results.length === 0) {
          console.log('No matches found.');
        } else {
          for (const r of result.results) {
            console.log(`\n${r.path} (${r.topic}) [${Array.isArray(r.tags) ? r.tags.join(', ') : ''}]`);
            console.log(r.snippet);
          }
        }
      }
      break;
    }

    case 'migrate': {
      const dryRun = hasFlag('dry-run');
      const result = await core.migrate({ dryRun });

      if (result.error) {
        console.error(result.error);
        process.exit(1);
      }

      console.log(`\nMigration ${dryRun ? 'plan' : 'complete'}: ${result.fileCount} files\n`);
      for (const f of result.plan) {
        console.log(`  ${f.path} (${f.topic})`);
        console.log(`    ${f.preview}\n`);
      }

      if (!dryRun) {
        console.log(result.message);
        console.log('\nPost-migration checklist:');
        console.log('  [ ] Check taxonomy: are files in the right directories?');
        console.log('  [ ] Check tags: do they make sense for your filtering needs?');
        console.log('  [ ] Update sync_order in index.md if needed');
        console.log('  [ ] Update agent prompts to use v2 tool names');
        console.log('  [ ] Test: pack status && pack validate');
      }
      break;
    }

    case 'sync': {
      const syncManager = new MemorySyncManager();
      await syncManager.init();

      if (!syncManager.enabled) {
        console.log('No sync targets configured.');
        process.exit(0);
      }

      const target = getFlag('target');
      const content = await core.getSyncContent();

      if (hasFlag('dry-run')) {
        console.log(`Would sync ${content.length} chars to: ${syncManager.targets.join(', ')}`);
        console.log('\n--- Preview (first 500 chars) ---');
        console.log(content.slice(0, 500));
        break;
      }

      console.log(`Syncing to: ${target || syncManager.targets.join(', ')}`);
      await syncManager.sync(content);
      console.log('Sync complete.');
      break;
    }

    case 'validate': {
      const result = await core.validate();
      if (result.mode === 'v1') {
        console.log(result.message);
        break;
      }

      console.log(`Checked ${result.fileCount} files`);

      if (result.errors.length) {
        console.log(`\nErrors (${result.errors.length}):`);
        for (const e of result.errors) console.log(`  ERROR: ${e}`);
      }

      if (result.warnings.length) {
        console.log(`\nWarnings (${result.warnings.length}):`);
        for (const w of result.warnings) console.log(`  WARN: ${w}`);
      }

      if (result.valid) {
        console.log('\nAll checks passed.');
      }

      process.exit(result.valid ? 0 : 1);
      break;
    }

    case 'status': {
      const result = await core.status();
      if (result.mode === 'v1') {
        console.log(`PACK v1 | 1 file | ${result.repo}`);
      } else {
        console.log(`PACK v2 | ${result.fileCount} files | Last updated: ${result.lastUpdated}`);
        console.log(`Mode:       v2 (directory)`);
        console.log(`Repo:       ${result.repo}`);
        if (result.directories) {
          const dirs = Object.entries(result.directories).map(([d, c]) => `${c} ${d}`).join(', ');
          console.log(`Files:      ${dirs}`);
        }
      }
      break;
    }

    default:
      console.error(`Unknown command: ${command}`);
      usage();
      process.exit(1);
  }
}

main().catch(err => {
  console.error(`Error: ${err.message}`);
  process.exit(1);
});
